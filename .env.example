# ============================================================
# EHS Compliance API - Environment Variable Template / 环境变量模板
#
# Usage / 用法:
#   1. Copy this file to .env  /  复制本文件为 .env
#        cp .env.example .env
#   2. Fill the values marked as "Required" / 填写标注为「必填」的字段
#   3. Never commit your .env (it is git-ignored) / 切勿提交真实 .env
#
# Production note / 生产提示:
#   When APP_ENV in {prod, production, live}, the app refuses to start
#   if any of these still hold dev defaults:
#     JWT_SECRET, MYSQL_PASSWORD, BOOTSTRAP_ADMIN_PASSWORD,
#     ADMIN_API_KEY (if used), DIFY_API_KEY, CORS_ORIGINS=*, APP_DEBUG=true
#   生产环境（APP_ENV=prod 等）下，上述字段保留默认值会阻止启动。
# ============================================================


# ---- App basics / 应用基础 ----
APP_NAME=EHS Compliance API
# dev / test / prod (validates production safety in prod)
APP_ENV=dev
APP_DEBUG=true


# ---- MySQL (Required / 必填) ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# Change this in any non-dev environment / 任何非开发环境必须修改
MYSQL_PASSWORD=changeme
MYSQL_DB=ehs_system


# ---- Bootstrap admin / 引导管理员 ----
# Created by init_db only if the username does not exist yet.
# To rotate the password, use scripts/upsert_bootstrap_admin.py
# init_db 仅在用户名不存在时创建；改密请用 scripts/upsert_bootstrap_admin.py
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe_Strong_Password


# ---- Redis / Celery ----
# DB 0 for broker, DB 1 for result backend by default
# 默认：DB 0 作 broker，DB 1 作 result backend
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1


# ---- Uploads / 上传 ----
UPLOAD_DIR=./uploads
# Single-file size limit in bytes (default 50MB)
# 单文件上限（字节），默认 50MB
MAX_UPLOAD_BYTES=52428800
# Days a soft-deleted upload is retained on disk before Beat cleans it
# 软删除文件保留天数，超期由 Beat 清理
UPLOAD_RETENTION_DAYS=7


# ---- Logging / 日志 ----
LOG_DIR=./logs
LOG_FILE=ehs_api.log
LOG_WORKER_FILE=ehs_worker.log
LOG_LEVEL=INFO


# ---- Security / 安全 ----
# JWT signing secret. MUST be a long random string in production (>= 32 chars).
# JWT 签名密钥；生产环境必须使用 32 字符以上的随机字符串。
JWT_SECRET=please-change-me-to-a-long-random-string
# JWT lifetime in minutes (default 24h)
# JWT 有效期（分钟），默认 24 小时
JWT_EXPIRE_MINUTES=1440

# Admin API key (sent via X-Admin-Key header). Leave empty to disable /admin/*.
# 管理员接口密钥（请求头 X-Admin-Key）；留空则 /api/v1/admin/* 返回 503。
ADMIN_API_KEY=

# Login captcha switch. Keep true for public deployments.
# 登录验证码开关；公网部署建议保持 true。
AUTH_CAPTCHA_REQUIRED=true

# CORS origins, comma separated; "*" means any.
# Note: "*" cannot be combined with browser credentials.
# CORS 源（逗号分隔，* 表示任意）；* 与浏览器 credentials 不可同时使用。
CORS_ORIGINS=*


# ---- Dify Workflow (Required / 必填) ----
# Get the key from Dify dashboard -> App -> API Access. Workflow apps only.
# 在 Dify 控制台「应用 -> API 访问」获取，仅工作流类型应用可用。
DIFY_API_KEY=app-replace-with-your-dify-api-key
# Cloud: https://api.dify.ai/v1   Self-hosted example: http://localhost/v1
# 云版：https://api.dify.ai/v1     自建示例：http://localhost/v1
DIFY_BASE_URL=https://api.dify.ai/v1
# Must match the variable name on Dify "End" node (default: result)
# 必须与 Dify「结束」节点输出变量名一致（默认 result）
DIFY_WORKFLOW_RESULT_KEY=result
# Must match the text variable name on Dify "Start" node (default: document_text)
# 必须与 Dify「开始」节点文本变量名一致（默认 document_text）
DIFY_WORKFLOW_INPUT_TEXT_KEY=document_text
# Conservative retry policy for recoverable Dify failures.
# Only 429, 5xx, and temporary network errors are retried by default.
# 对 Dify 可恢复错误采用保守重试；默认只重试 429、5xx 和临时网络错误。
DIFY_RETRY_MAX_ATTEMPTS=3
DIFY_RETRY_INITIAL_DELAY_SECONDS=2
DIFY_RETRY_MAX_DELAY_SECONDS=10
DIFY_RETRY_JITTER_SECONDS=0.5
# Blocking timeout may mean Dify is still running; keep false to avoid duplicate billing.
# 阻塞超时可能表示 Dify 仍在执行；默认 false，避免重复扣费和重复执行。
DIFY_RETRY_ON_TIMEOUT=false


# ---- Outbound HTTP (Optional / 可选) ----
# Some gateways block default Python-urllib UA; override here if needed.
# 某些网关拦截默认 Python-urllib UA；按需覆盖。
# HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) ...


# ---- PDF OCR (Optional / 可选) ----
# Keep false for lightweight small-server deployments. Set true only when the
# worker image includes requirements-ocr.txt, for example with docker-compose.ocr.yml.
# 小服务器轻量部署建议保持 false。只有 Worker 镜像安装 requirements-ocr.txt
# 并使用 docker-compose.ocr.yml 等 OCR 配置时才设置为 true。
PDF_OCR_ENABLED=false
